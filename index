<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>旅の本屋さん地図</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@400;700&family=Shippori+Mincho:wght@400;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<style>
  :root {
    --ink: #1a1208;
    --paper: #f5f0e8;
    --aged: #e8dfc8;
    --accent: #8b3a1a;
    --accent2: #2d5a3d;
    --muted: #8a7d6b;
    --shadow: rgba(26,18,8,0.15);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Noto Serif JP', serif;
    background: var(--paper);
    color: var(--ink);
    height: 100dvh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  /* ヘッダー */
  header {
    background: var(--ink);
    color: var(--paper);
    padding: 10px 16px 8px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    flex-shrink: 0;
    box-shadow: 0 2px 8px var(--shadow);
    z-index: 1000;
  }

  .header-title {
    font-family: 'Shippori Mincho', serif;
    font-size: 18px;
    font-weight: 700;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }
  .header-title span { color: #c8956a; }

  /* 検索バー */
  .search-wrap {
    flex: 1;
    position: relative;
    max-width: 280px;
  }
  .search-wrap input {
    width: 100%;
    padding: 7px 12px 7px 32px;
    border-radius: 20px;
    border: none;
    background: rgba(245,240,232,0.15);
    color: var(--paper);
    font-family: 'Noto Serif JP', serif;
    font-size: 13px;
    outline: none;
  }
  .search-wrap input::placeholder { color: rgba(245,240,232,0.5); }
  .search-icon {
    position: absolute;
    left: 10px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 13px;
    opacity: 0.6;
  }

  /* フィルターバー */
  .filter-bar {
    background: var(--aged);
    padding: 8px 12px;
    display: flex;
    gap: 8px;
    overflow-x: auto;
    flex-shrink: 0;
    scrollbar-width: none;
    border-bottom: 1px solid rgba(26,18,8,0.1);
  }
  .filter-bar::-webkit-scrollbar { display: none; }

  .filter-chip {
    flex-shrink: 0;
    padding: 4px 12px;
    border-radius: 14px;
    border: 1.5px solid var(--muted);
    background: transparent;
    color: var(--ink);
    font-family: 'Noto Serif JP', serif;
    font-size: 12px;
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
  }
  .filter-chip.active {
    background: var(--accent);
    border-color: var(--accent);
    color: white;
  }

  /* メインレイアウト */
  .main {
    flex: 1;
    position: relative;
    overflow: hidden;
  }

  /* 地図 */
  #map {
    width: 100%;
    height: 100%;
  }

  /* 件数バッジ */
  .count-badge {
    position: absolute;
    top: 10px;
    left: 10px;
    z-index: 800;
    background: var(--ink);
    color: var(--paper);
    padding: 4px 10px;
    border-radius: 10px;
    font-size: 12px;
    font-family: 'Noto Serif JP', serif;
    pointer-events: none;
    opacity: 0.85;
  }

  /* 現在地ボタン */
  .locate-btn {
    position: absolute;
    bottom: 200px;
    right: 14px;
    z-index: 800;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: white;
    border: none;
    box-shadow: 0 2px 8px var(--shadow);
    font-size: 20px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.15s;
  }
  .locate-btn:active { transform: scale(0.92); }

  /* 下部パネル */
  .bottom-panel {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 900;
    background: var(--paper);
    border-radius: 18px 18px 0 0;
    box-shadow: 0 -4px 20px var(--shadow);
    max-height: 50vh;
    display: flex;
    flex-direction: column;
    transition: transform 0.3s ease;
  }
  .bottom-panel.collapsed { transform: translateY(calc(100% - 52px)); }

  .panel-handle-area {
    padding: 12px 16px 10px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-shrink: 0;
    border-bottom: 1px solid rgba(26,18,8,0.08);
  }
  .panel-handle {
    width: 36px;
    height: 4px;
    background: var(--muted);
    border-radius: 2px;
    margin: 0 auto 8px;
    display: block;
  }
  .panel-title {
    font-size: 13px;
    font-weight: 700;
    color: var(--muted);
    letter-spacing: 0.05em;
  }

  /* 店舗リスト */
  .store-list {
    overflow-y: auto;
    flex: 1;
    padding: 8px 0 env(safe-area-inset-bottom, 0);
  }
  .store-item {
    padding: 10px 16px;
    border-bottom: 1px solid rgba(26,18,8,0.06);
    cursor: pointer;
    display: flex;
    align-items: flex-start;
    gap: 10px;
    transition: background 0.15s;
  }
  .store-item:active { background: var(--aged); }
  .store-item.highlighted { background: rgba(139,58,26,0.08); }

  .store-icon {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background: var(--accent);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .store-info { flex: 1; min-width: 0; }
  .store-name {
    font-size: 14px;
    font-weight: 700;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .store-address {
    font-size: 11px;
    color: var(--muted);
    margin-top: 2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .store-pref {
    font-size: 10px;
    background: var(--aged);
    color: var(--muted);
    padding: 2px 6px;
    border-radius: 8px;
    flex-shrink: 0;
    align-self: center;
  }

  /* ポップアップカスタム */
  .leaflet-popup-content-wrapper {
    border-radius: 12px !important;
    box-shadow: 0 4px 20px rgba(0,0,0,0.2) !important;
    font-family: 'Noto Serif JP', serif !important;
    padding: 0 !important;
    overflow: hidden;
  }
  .leaflet-popup-content {
    margin: 0 !important;
    width: 220px !important;
  }
  .popup-inner {
    padding: 12px 14px;
  }
  .popup-name {
    font-size: 14px;
    font-weight: 700;
    color: var(--ink);
    line-height: 1.4;
    margin-bottom: 4px;
  }
  .popup-addr {
    font-size: 11px;
    color: var(--muted);
    line-height: 1.5;
    margin-bottom: 10px;
  }
  .popup-btn {
    display: block;
    background: var(--accent);
    color: white;
    text-align: center;
    padding: 8px;
    font-size: 12px;
    font-family: 'Noto Serif JP', serif;
    text-decoration: none;
    border-radius: 0 0 12px 12px;
    letter-spacing: 0.05em;
    font-weight: 700;
    transition: background 0.2s;
  }

  /* ローディング */
  .loading {
    position: absolute;
    inset: 0;
    background: var(--paper);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 2000;
    gap: 16px;
  }
  .loading-title {
    font-family: 'Shippori Mincho', serif;
    font-size: 22px;
    font-weight: 700;
    color: var(--ink);
  }
  .loading-title span { color: var(--accent); }
  .loading-dot {
    display: flex;
    gap: 6px;
  }
  .dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--accent);
    animation: bounce 1.2s infinite;
  }
  .dot:nth-child(2) { animation-delay: 0.2s; }
  .dot:nth-child(3) { animation-delay: 0.4s; }
  @keyframes bounce {
    0%,80%,100% { transform: translateY(0); opacity: 0.4; }
    40% { transform: translateY(-8px); opacity: 1; }
  }
  .loading-sub {
    font-size: 12px;
    color: var(--muted);
  }

  /* エラー */
  .error-box {
    position: absolute;
    inset: 0;
    background: var(--paper);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 2000;
    gap: 12px;
    padding: 24px;
    text-align: center;
  }
  .error-box h2 { font-size: 18px; color: var(--accent); }
  .error-box p { font-size: 13px; color: var(--muted); line-height: 1.7; }
</style>
</head>
<body>

<!-- ローディング -->
<div class="loading" id="loading">
  <div class="loading-title">旅の<span>本屋さん</span></div>
  <div class="loading-dot">
    <div class="dot"></div>
    <div class="dot"></div>
    <div class="dot"></div>
  </div>
  <div class="loading-sub">本屋さんデータを読み込んでいます…</div>
</div>

<!-- エラー表示 -->
<div class="error-box" id="error-box" style="display:none">
  <h2>📚 読み込みエラー</h2>
  <p id="error-msg">データの取得に失敗しました。<br>スプレッドシートの共有設定を確認してください。</p>
</div>

<header>
  <div class="header-title">旅の<span>本屋</span>さん</div>
  <div class="search-wrap">
    <span class="search-icon">🔍</span>
    <input type="text" id="search-input" placeholder="店名・地名で検索…">
  </div>
</header>

<div class="filter-bar" id="filter-bar">
  <button class="filter-chip active" data-pref="all">すべて</button>
</div>

<div class="main">
  <div id="map"></div>
  <div class="count-badge" id="count-badge">読込中…</div>
  <button class="locate-btn" id="locate-btn" title="現在地">📍</button>

  <div class="bottom-panel collapsed" id="bottom-panel">
    <div class="panel-handle-area" id="panel-toggle">
      <div style="flex:1">
        <span class="panel-handle"></span>
        <div class="panel-title" id="panel-title">📚 本屋さんリスト</div>
      </div>
    </div>
    <div class="store-list" id="store-list"></div>
  </div>
</div>

<script>
// =============================================
// 設定：スプレッドシートID（ここだけ変更すればOK）
// =============================================
const SHEET_ID = '1_sTQ9Jtj1ZFHD-CGnw4-R36ilQvl1QBcfLjfylPpbnc';
const GID = '1346886823';
const CSV_URL = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/export?format=csv&gid=${GID}`;

// =============================================
// 地図初期化
// =============================================
const map = L.map('map', {
  center: [36.5, 137.5],
  zoom: 6,
  zoomControl: true,
});

L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
  attribution: '© OpenStreetMap contributors © CARTO',
  maxZoom: 18,
}).addTo(map);

// カスタムマーカーアイコン
const bookIcon = L.divIcon({
  className: '',
  html: `<div style="
    width:28px;height:28px;
    background:#8b3a1a;
    border-radius:50% 50% 50% 0;
    transform:rotate(-45deg);
    border:2px solid white;
    box-shadow:0 2px 6px rgba(0,0,0,0.3);
    display:flex;align-items:center;justify-content:center;
  "><span style="transform:rotate(45deg);font-size:13px;display:block;text-align:center;line-height:24px;">📚</span></div>`,
  iconSize: [28, 28],
  iconAnchor: [14, 28],
  popupAnchor: [0, -30],
});

// =============================================
// データ管理
// =============================================
let allStores = [];
let markers = [];
let markerGroup = L.layerGroup().addTo(map);
let currentPref = 'all';
let currentSearch = '';
let panelOpen = false;

// CSVパース
function parseCSV(text) {
  const lines = text.trim().split('\n');
  const header = lines[0].split(',').map(h => h.trim().replace(/^"|"$/g,''));
  return lines.slice(1).map(line => {
    const cols = [];
    let cur = '', inQ = false;
    for(let i=0;i<line.length;i++){
      const c = line[i];
      if(c==='"') inQ=!inQ;
      else if(c===','&&!inQ){ cols.push(cur); cur=''; }
      else cur+=c;
    }
    cols.push(cur);
    const obj = {};
    header.forEach((h,i) => obj[h] = (cols[i]||'').trim().replace(/^"|"$/g,''));
    return obj;
  });
}

// データ読み込み
async function loadData() {
  try {
    const res = await fetch(CSV_URL);
    if(!res.ok) throw new Error('HTTP ' + res.status);
    const text = await res.text();
    const rows = parseCSV(text);
    allStores = rows.filter(r => {
      const lat = parseFloat(r['緯度'] || r['lat'] || '');
      const lng = parseFloat(r['経度'] || r['lng'] || r['lon'] || '');
      return !isNaN(lat) && !isNaN(lng) && lat !== 0 && lng !== 0;
    }).map(r => ({
      name: r['店名'] || '',
      pref: r['都道府県'] || '',
      address: r['所在地'] || '',
      lat: parseFloat(r['緯度'] || r['lat']),
      lng: parseFloat(r['経度'] || r['lng'] || r['lon']),
      source: r['参照リスト'] || '',
    }));

    buildPrefFilter();
    renderMarkers();
    document.getElementById('loading').style.display = 'none';
  } catch(e) {
    document.getElementById('loading').style.display = 'none';
    document.getElementById('error-box').style.display = 'flex';
    document.getElementById('error-msg').textContent =
      'データの取得に失敗しました。\nスプレッドシートを「リンクを知っている人が閲覧可能」に設定してください。\n\nエラー: ' + e.message;
  }
}

// 都道府県フィルター構築
function buildPrefFilter() {
  const prefs = [...new Set(allStores.map(s=>s.pref))].sort((a,b)=>{
    const codeA = allStores.find(s=>s.pref===a);
    const codeB = allStores.find(s=>s.pref===b);
    return 0;
  });
  const bar = document.getElementById('filter-bar');
  prefs.forEach(p => {
    const btn = document.createElement('button');
    btn.className = 'filter-chip';
    btn.dataset.pref = p;
    btn.textContent = p;
    btn.addEventListener('click', () => {
      currentPref = p;
      document.querySelectorAll('.filter-chip').forEach(c=>c.classList.remove('active'));
      btn.classList.add('active');
      renderMarkers();
      const stores = getFilteredStores();
      if(stores.length > 0){
        const lats = stores.map(s=>s.lat);
        const lngs = stores.map(s=>s.lng);
        map.fitBounds([[Math.min(...lats),Math.min(...lngs)],[Math.max(...lats),Math.max(...lngs)]], {padding:[40,40]});
      }
    });
    bar.appendChild(btn);
  });
  document.querySelector('.filter-chip[data-pref="all"]').addEventListener('click', ()=>{
    currentPref = 'all';
    document.querySelectorAll('.filter-chip').forEach(c=>c.classList.remove('active'));
    document.querySelector('.filter-chip[data-pref="all"]').classList.add('active');
    renderMarkers();
  });
}

function getFilteredStores() {
  return allStores.filter(s => {
    if(currentPref !== 'all' && s.pref !== currentPref) return false;
    if(currentSearch) {
      const q = currentSearch.toLowerCase();
      return s.name.toLowerCase().includes(q) || s.address.toLowerCase().includes(q) || s.pref.includes(q);
    }
    return true;
  });
}

// マーカー描画
function renderMarkers() {
  markerGroup.clearLayers();
  const stores = getFilteredStores();
  document.getElementById('count-badge').textContent = `📚 ${stores.length}件`;

  stores.forEach((s, i) => {
    const m = L.marker([s.lat, s.lng], { icon: bookIcon });
    const mapsUrl = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(s.name + ' ' + s.address)}`;
    m.bindPopup(`
      <div class="popup-inner">
        <div class="popup-name">${s.name}</div>
        <div class="popup-addr">${s.pref}<br>${s.address}</div>
      </div>
      <a class="popup-btn" href="${mapsUrl}" target="_blank" rel="noopener">🗺 Googleマップで開く</a>
    `);
    m.on('click', () => {
      highlightListItem(i, s);
    });
    markerGroup.addLayer(m);
  });

  renderList(stores);
}

// リスト描画
function renderList(stores) {
  const list = document.getElementById('store-list');
  list.innerHTML = '';
  const title = document.getElementById('panel-title');
  title.textContent = `📚 ${stores.length}件の本屋さん`;

  stores.forEach((s, i) => {
    const item = document.createElement('div');
    item.className = 'store-item';
    item.dataset.idx = i;
    item.innerHTML = `
      <div class="store-icon">📚</div>
      <div class="store-info">
        <div class="store-name">${s.name}</div>
        <div class="store-address">${s.address}</div>
      </div>
      <span class="store-pref">${s.pref}</span>
    `;
    item.addEventListener('click', () => {
      map.flyTo([s.lat, s.lng], 15, {duration: 0.8});
      setTimeout(() => {
        markerGroup.eachLayer(m => {
          if(Math.abs(m.getLatLng().lat - s.lat) < 0.0001) m.openPopup();
        });
      }, 900);
      // パネルを閉じる
      panelOpen = false;
      document.getElementById('bottom-panel').classList.add('collapsed');
    });
    list.appendChild(item);
  });
}

function highlightListItem(i, s) {
  document.querySelectorAll('.store-item').forEach(el => el.classList.remove('highlighted'));
  const el = document.querySelector(`.store-item[data-idx="${i}"]`);
  if(el){
    el.classList.add('highlighted');
    el.scrollIntoView({behavior:'smooth', block:'nearest'});
  }
}

// パネル開閉
document.getElementById('panel-toggle').addEventListener('click', () => {
  panelOpen = !panelOpen;
  document.getElementById('bottom-panel').classList.toggle('collapsed', !panelOpen);
});

// 検索
document.getElementById('search-input').addEventListener('input', e => {
  currentSearch = e.target.value.trim();
  renderMarkers();
});

// 現在地
document.getElementById('locate-btn').addEventListener('click', () => {
  if(!navigator.geolocation){ alert('位置情報が使えません'); return; }
  navigator.geolocation.getCurrentPosition(pos => {
    const {latitude:lat, longitude:lng} = pos.coords;
    map.flyTo([lat, lng], 13, {duration:1});
    L.marker([lat,lng], {
      icon: L.divIcon({
        className:'',
        html:`<div style="width:14px;height:14px;background:#2d5a3d;border-radius:50%;border:3px solid white;box-shadow:0 0 0 4px rgba(45,90,61,0.3)"></div>`,
        iconSize:[14,14], iconAnchor:[7,7]
      })
    }).addTo(map).bindPopup('現在地').openPopup();
  }, () => alert('位置情報の取得に失敗しました'));
});

// 起動
loadData();
</script>
</body>
</html>
